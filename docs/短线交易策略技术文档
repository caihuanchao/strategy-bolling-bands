def ai_dynamic_stop_loss(data, risk_ratio=0.02):
    """
    2026年AI动态止损 - 基于波动率和趋势强度
    """
    # 计算ATR (14日)
    data['tr1'] = data['high'] - data['low']
    data['tr2'] = abs(data['high'] - data['close'].shift(1))
    data['tr3'] = abs(data['low'] - data['close'].shift(1))
    data['tr'] = data[['tr1', 'tr2', 'tr3']].max(axis=1)
    data['atr'] = data['tr'].rolling(14).mean()
    
    # 计算趋势强度
    data['trend_strength'] = abs(data['middle_band'].diff(5)) / data['middle_band']
    
    # 动态止损位
    data['stop_loss_long'] = data['close'] - (data['atr'] * (1 + data['trend_strength'] * 2))
    data['stop_loss_short'] = data['close'] + (data['atr'] * (1 + data['trend_strength'] * 2))
    
    # 风险控制：最大亏损不超过2%
    data['max_stop_loss'] = data['close'] * (1 - risk_ratio)
    data['stop_loss_long'] = data[['stop_loss_long', 'max_stop_loss']].max(axis=1)
    
    return data
