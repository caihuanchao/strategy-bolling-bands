def add_market_sentiment_filter(data):
    """
    2026年新增：市场情绪过滤
    利用涨跌家数比、涨停跌停比等情绪指标
    """
    # 假设我们有情绪数据
    data['advance_decline_ratio'] = data['advancing_stocks'] / data['declining_stocks']
    data['limit_up_down_ratio'] = data['limit_up_count'] / (data['limit_down_count'] + 1)
    
    # 情绪过滤规则
    data['sentiment_bullish'] = (
        (data['advance_decline_ratio'] > 1.5) &
        (data['limit_up_down_ratio'] > 3) &
        (data['market_volume'] > data['market_volume'].rolling(5).mean())
    )
    
    data['sentiment_bearish'] = (
        (data['advance_decline_ratio'] < 0.7) &
        (data['limit_up_down_ratio'] < 0.3) &
        (data['market_volume'] > data['market_volume'].rolling(5).mean())
    )
    
    return data
