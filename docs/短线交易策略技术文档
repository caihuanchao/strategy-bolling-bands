from sklearn.preprocessing import MinMaxScaler
from keras.models import Sequential
from keras.layers import LSTM, Dense, Dropout

def lstm_prediction_strategy(data, lookback=60):
    """
    2026年深度学习短线策略
    - LSTM预测未来5分钟价格走势
    - 结合技术指标过滤
    """
    # 数据准备
    scaler = MinMaxScaler()
    scaled_data = scaler.fit_transform(data[['close', 'volume', 'high', 'low']].values)
    
    # 创建训练序列
    X, y = [], []
    for i in range(lookback, len(scaled_data)-5):
        X.append(scaled_data[i-lookback:i])
        y.append(scaled_data[i+5, 0])  # 预测5个周期后的收盘价
    
    X, y = np.array(X), np.array(y)
    
    # 构建LSTM模型
    model = Sequential([
        LSTM(50, return_sequences=True, input_shape=(lookback, 4)),
        Dropout(0.2),
        LSTM(50, return_sequences=False),
        Dropout(0.2),
        Dense(1)
    ])
    
    model.compile(optimizer='adam', loss='mse')
    model.fit(X, y, epochs=50, batch_size=32, verbose=0)
    
    # 预测和信号生成
    last_sequence = scaled_data[-lookback:].reshape(1, lookback, 4)
    prediction = model.predict(last_sequence)[0][0]
    current_price = data['close'].iloc[-1]
    
    # 预测信号
    predicted_price = scaler.inverse_transform(
        np.array([[prediction, 0, 0, 0]]))[0][0]
    
    data['lstm_signal'] = 0
    if predicted_price > current_price * 1.005:  # 预测上涨0.5%以上
        data.loc[data.index[-1], 'lstm_signal'] = 1
    elif predicted_price < current_price * 0.995:  # 预测下跌0.5%以上
        data.loc[data.index[-1], 'lstm_signal'] = -1
    
    return data
