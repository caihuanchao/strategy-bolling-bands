def bollinger_band_strategy(data, window=20, std_dev=2):
    """
    2026年优化版布林带策略
    - 增加趋势过滤：只在中轨向上时做多
    - 增加成交量验证：突破时需放量
    - 增加动态参数：根据波动率调整标准差倍数
    """
    # 计算布林带
    data['middle_band'] = data['close'].rolling(window=window).mean()
    data['std'] = data['close'].rolling(window=window).std()
    data['upper_band'] = data['middle_band'] + std_dev * data['std']
    data['lower_band'] = data['middle_band'] - std_dev * data['std']
    
    # 趋势过滤：中轨斜率
    data['middle_slope'] = data['middle_band'].diff(3)  # 3日斜率
    
    # 信号生成
    data['long_signal'] = (
        (data['close'] < data['lower_band']) &  # 价格触及下轨
        (data['middle_slope'] > 0) &             # 中轨向上
        (data['volume'] > data['volume'].rolling(5).mean() * 1.2)  # 放量验证
    )
    
    data['short_signal'] = (
        (data['close'] > data['upper_band']) &   # 价格触及上轨
        (data['middle_slope'] < 0) &             # 中轨向下
        (data['volume'] > data['volume'].rolling(5).mean() * 1.2)  # 放量验证
    )
    
    return data
