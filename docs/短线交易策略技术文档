def order_flow_strategy(tick_data):
    """
    2026年订单流分析策略
    - 分析大单成交方向
    - 识别主力资金流向
    """
    # 大单定义（可调整）
    LARGE_ORDER_THRESHOLD = tick_data['volume'].quantile(0.95)
    
    # 标记大单
    tick_data['is_large_order'] = tick_data['volume'] > LARGE_ORDER_THRESHOLD
    tick_data['large_order_direction'] = np.where(
        tick_data['price'] > tick_data['mid_price'].shift(1),
        1,  # 主动买入
        np.where(tick_data['price'] < tick_data['mid_price'].shift(1), -1, 0)  # 主动卖出
    )
    
    # 订单流不平衡
    tick_data['order_flow_imbalance'] = (
        tick_data['large_order_direction'] * tick_data['volume']
    ).rolling(50).sum()
    
    # 信号生成
    tick_data['flow_long'] = (
        tick_data['order_flow_imbalance'] > tick_data['order_flow_imbalance'].rolling(200).mean() * 1.5
    )
    
    tick_data['flow_short'] = (
        tick_data['order_flow_imbalance'] < tick_data['order_flow_imbalance'].rolling(200).mean() * -1.5
    )
    
    return tick_data
