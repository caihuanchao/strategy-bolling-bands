def kdj_boll_volume_strategy(data, k_period=9, d_period=3):
    """
    2026年震荡行情优化策略
    特别适合注册制后的A股震荡市
    """
    # 1. KDJ计算
    low_min = data['low'].rolling(k_period).min()
    high_max = data['high'].rolling(k_period).max()
    data['rsv'] = (data['close'] - low_min) / (high_max - low_min) * 100
    data['k'] = data['rsv'].ewm(alpha=1/d_period, adjust=False).mean()
    data['d'] = data['k'].ewm(alpha=1/d_period, adjust=False).mean()
    data['j'] = 3 * data['k'] - 2 * data['d']
    
    # 2. 布林带
    data = bollinger_band_strategy(data, window=20, std_dev=2)
    
    # 3. 成交量均线
    data['vol_ma5'] = data['volume'].rolling(5).mean()
    data['vol_ratio'] = data['volume'] / data['vol_ma5']
    
    # 4. 震荡行情信号
    # 低位金叉反弹
    data['kdj_boll_long'] = (
        (data['k'] < 25) & (data['d'] < 25) &  # KDJ超卖区
        (data['k'] > data['d']) &              # KDJ金叉
        (data['close'] < data['lower_band'] * 1.03) &  # 价格在下轨附近
        (data['vol_ratio'] > 1.5) &            # 成交量放大
        (data['middle_band'].diff(2) > 0)      # 中轨开始走平或向上
    )
    
    # 高位死叉回落
    data['kdj_boll_short'] = (
        (data['k'] > 75) & (data['d'] > 75) &  # KDJ超买区
        (data['k'] < data['d']) &              # KDJ死叉
        (data['close'] > data['upper_band'] * 0.97) &  # 价格在上轨附近
        (data['vol_ratio'] > 1.5) &            # 成交量放大
        (data['middle_band'].diff(2) < 0)      # 中轨开始走平或向下
    )
    
    return data
