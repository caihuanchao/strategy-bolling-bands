import gym
from stable_baselines3 import PPO

class TradingEnv(gym.Env):
    """2026年强化学习交易环境"""
    def __init__(self, df):
        super(TradingEnv, self).__init__()
        self.df = df
        self.current_step = 0
        self.action_space = gym.spaces.Discrete(3)  # 0:持币, 1:持多, 2:持空
        self.observation_space = gym.spaces.Box(
            low=-np.inf, high=np.inf, shape=(10,), dtype=np.float32
        )
    
    def reset(self):
        self.current_step = 0
        return self._get_observation()
    
    def step(self, action):
        # 执行交易逻辑
        reward = self._calculate_reward(action)
        self.current_step += 1
        done = self.current_step >= len(self.df) - 1
        obs = self._get_observation()
        
        return obs, reward, done, {}
    
    def _get_observation(self):
        # 特征工程：价格、波动率、技术指标等
        obs = np.array([
            self.df['close'].iloc[self.current_step] / self.df['close'].iloc[self.current_step-1] - 1,
            self.df['volume'].iloc[self.current_step] / self.df['volume'].mean(),
            self.df['rsi'].iloc[self.current_step] / 100,
            self.df['macd'].iloc[self.current_step],
            self.df['atr'].iloc[self.current_step] / self.df['close'].iloc[self.current_step],
            # ... 其他特征
        ])
        return obs.astype(np.float32)

def ppo_trading_strategy(data):
    """PPO强化学习策略"""
    env = TradingEnv(data)
    model = PPO('MlpPolicy', env, verbose=0)
    model.learn(total_timesteps=10000)
    
    # 生成交易信号
    obs = env.reset()
    signals = []
    for _ in range(len(data)):
        action, _ = model.predict(obs)
        signals.append(action)
        obs, _, done, _ = env.step(action)
        if done:
            break
    
    data['rl_signal'] = 0
    data.loc[:len(signals)-1, 'rl_signal'] = signals
    
    return data
