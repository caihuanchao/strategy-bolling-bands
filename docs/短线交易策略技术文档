def risk_management_2026(strategy_signals, account_risk=0.02):
    """
    2026年最新风险管理规则
    - 单笔交易最大风险2%
    - 单日最大亏损5%
    - 波动率自适应仓位
    """
    # 计算最大可承受损失
    max_loss_per_trade = account_balance * account_risk
    
    # 动态仓位计算
    strategy_signals['position_size'] = max_loss_per_trade / (
        abs(strategy_signals['entry_price'] - strategy_signals['stop_loss'])
    )
    
    # 单日风险控制
    today_loss = calculate_today_loss()
    if today_loss > account_balance * 0.05:
        strategy_signals['position_size'] = 0  # 停止交易
    
    # 波动率调整
    volatility_factor = 1 / (strategy_signals['atr'] / strategy_signals['close'])
    strategy_signals['position_size'] *= volatility_factor.clip(0.5, 2.0)
    
    return strategy_signals
