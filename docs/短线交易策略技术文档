def strategy_failure_detection(data):
    # 检测策略失效（连续5次亏损）
    recent_losses = data['pnl'].tail(5).sum() < 0
    volatility_spike = data['atr'].iloc[-1] > data['atr'].rolling(30).mean() * 2
    
    if recent_losses and volatility_spike:
        return "市场环境变化，切换策略"
    elif recent_losses and not volatility_spike:
        return "策略参数需要优化"
    else:
        return "正常波动"
