def slippage_control(data):
    # 动态调整订单大小
    liquidity_factor = data['volume'].rolling(10).mean() / data['volume'].mean()
    max_order_size = base_order_size * liquidity_factor.clip(0.3, 2.0)
    
    # 避免高波动时段
    if data['atr'].iloc[-1] > data['atr'].rolling(60).mean() * 1.5:
        return max_order_size * 0.5  # 减半仓位
