def tick_arbitrage_strategy(tick_data):
    """
    2026年高频价差套利策略
    - 适用于Level2行情
    - 买卖价差套利
    """
    # 计算买卖价差
    tick_data['bid_ask_spread'] = tick_data['ask_price1'] - tick_data['bid_price1']
    tick_data['mid_price'] = (tick_data['ask_price1'] + tick_data['bid_price1']) / 2
    
    # 价差异常检测
    tick_data['spread_mean'] = tick_data['bid_ask_spread'].rolling(100).mean()
    tick_data['spread_std'] = tick_data['bid_ask_spread'].rolling(100).std()
    
    # 套利信号
    tick_data['arbitrage_long'] = (
        (tick_data['bid_ask_spread'] > tick_data['spread_mean'] + 2 * tick_data['spread_std']) &
        (tick_data['bid_volume1'] > tick_data['ask_volume1'] * 1.5)  # 买单优势
    )
    
    tick_data['arbitrage_short'] = (
        (tick_data['bid_ask_spread'] > tick_data['spread_mean'] + 2 * tick_data['spread_std']) &
        (tick_data['ask_volume1'] > tick_data['bid_volume1'] * 1.5)  # 卖单优势
    )
    
    return tick_data
