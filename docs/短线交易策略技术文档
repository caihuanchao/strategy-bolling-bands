def dual_ma_strategy(data):
    """
    2026年优化版双均线策略
    - 5日EMA（快线）和20日EMA（慢线）
    - 加入成交量过滤
    - 动态止损机制
    """
    data['ema5'] = data['close'].ewm(span=5, adjust=False).mean()
    data['ema20'] = data['close'].ewm(span=20, adjust=False).mean()
    data['volume_ma'] = data['volume'].rolling(10).mean()
    
    # 金叉信号（多头）
    data['golden_cross'] = (
        (data['ema5'] > data['ema20']) & 
        (data['ema5'].shift(1) <= data['ema20'].shift(1)) &
        (data['volume'] > data['volume_ma'] * 1.2)  # 成交量放大确认
    )
    
    # 死叉信号（空头）  
    data['death_cross'] = (
        (data['ema5'] < data['ema20']) & 
        (data['ema5'].shift(1) >= data['ema20'].shift(1)) &
        (data['volume'] > data['volume_ma'] * 1.2)
    )
    
    # 动态止损（ATR-based）
    data['atr'] = data['high'] - data['low']
    data['atr'] = data['atr'].rolling(14).mean()
    data['stop_loss'] = data['close'] - 1.5 * data['atr']
    
    return data
