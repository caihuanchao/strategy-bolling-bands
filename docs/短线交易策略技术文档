def kdj_boll_atr_strategy(data):
    """
    2026年波动率自适应策略
    - KDJ提供超买超卖信号
    - 布林带提供价格区间
    - ATR动态调整仓位和止损
    """
    # 1. KDJ (9,3,3)
    low_min = data['low'].rolling(9).min()
    high_max = data['high'].rolling(9).max()
    data['rsv'] = (data['close'] - low_min) / (high_max - low_min) * 100
    data['k'] = data['rsv'].ewm(alpha=1/3, adjust=False).mean()
    data['d'] = data['k'].ewm(alpha=1/3, adjust=False).mean()
    data['j'] = 3 * data['k'] - 2 * data['d']
    
    # 2. 布林带 (20,2)
    data = bollinger_mean_reversion(data)
    
    # 3. ATR (14日)
    data['tr1'] = data['high'] - data['low']
    data['tr2'] = abs(data['high'] - data['close'].shift(1))
    data['tr3'] = abs(data['low'] - data['close'].shift(1))
    data['tr'] = data[['tr1', 'tr2', 'tr3']].max(axis=1)
    data['atr'] = data['tr'].rolling(14).mean()
    
    # 4. 融合信号
    data['kdj_boll_long'] = (
        (data['k'] < 25) & (data['d'] < 25) &  # KDJ超卖区
        (data['k'] > data['d']) &              # KDJ金叉
        (data['close'] <= data['lower_band'] * 1.02) &  # 价格在下轨附近
        (data['atr'] > data['atr'].rolling(30).mean() * 0.8)  # 有足够波动性
    )
    
    data['kdj_boll_short'] = (
        (data['k'] > 75) & (data['d'] > 75) &  # KDJ超买区
        (data['k'] < data['d']) &              # KDJ死叉
        (data['close'] >= data['upper_band'] * 0.98) &  # 价格在上轨附近
        (data['atr'] > data['atr'].rolling(30).mean() * 0.8)
    )
    
    # 5. 动态仓位管理
    data['position_size'] = 0.5 / (data['atr'] / data['close'])  # 波动率倒数仓位
    data['position_size'] = data['position_size'].clip(0.1, 1.0)  # 仓位限制10%-100%
    
    return data
