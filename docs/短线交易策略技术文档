def bollinger_squeeze_strategy(data, squeeze_threshold=0.1):
    """
    布林带收口突破策略 - 2026年高频交易首选
    逻辑：当布林带宽度小于阈值时，预示即将爆发性行情
    """
    # 计算布林带宽度
    data['band_width'] = data['upper_band'] - data['lower_band']
    data['band_width_pct'] = data['band_width'] / data['middle_band']
    
    # 识别收口状态
    data['is_squeeze'] = data['band_width_pct'] < squeeze_threshold
    
    # 突破信号
    data['breakout_up'] = (
        data['is_squeeze'].shift(1) &  # 前期收口
        (data['close'] > data['upper_band'].shift(1)) &  # 向上突破
        (data['volume'] > data['volume'].rolling(10).mean() * 1.5)  # 显著放量
    )
    
    data['breakout_down'] = (
        data['is_squeeze'].shift(1) &  # 前期收口
        (data['close'] < data['lower_band'].shift(1)) &  # 向下突破
        (data['volume'] > data['volume'].rolling(10).mean() * 1.5)  # 显著放量
    )
    
    return data
